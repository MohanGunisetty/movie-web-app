# Render Deployment Environment Variables
# The following variables will be automatically configured by the `render.yaml` Blueprint:
# - DATABASE_URL
# - SECRET_KEY
# - ALGORITHM
# - ACCESS_TOKEN_EXPIRE_MINUTES

# You MUST manually supply these variables in the Render Dashboard -> Environment:
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
ADMIN_EMAIL=admin@example.com

# Upload Directory - the default paths set in render.yaml
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
